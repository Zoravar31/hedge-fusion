# ── AI Model (Required) ──────────────────────────────────────
OPENAI_API_KEY=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

# gpt-4o-mini → ~₹2-5 per stock run (use for testing)
# gpt-4o      → ~₹20-50 per stock run (use for live decisions)
MODEL_NAME=gpt-4o-mini

# ── Trading Mode ─────────────────────────────────────────────
# true  = paper trades (safe, default — START HERE)
# false = live trades via Zerodha Kite
KITE_PAPER_TRADE=true

# ── Zerodha Kite (Required only for live trading) ─────────────
# Get from: https://developers.kite.trade/ (₹2000/year)
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=   # Auto-filled by: python tools/kite_login.py

# ── Portfolio ─────────────────────────────────────────────────
PORTFOLIO_SIZE_INR=500000

# ── Scheduler ─────────────────────────────────────────────────
SCHEDULE_MODE=daily
SCHEDULE_TIME=09:30
SCHEDULE_TICKERS=RELIANCE,HDFCBANK,ICICIBANK
SCHEDULE_EXECUTE=false
