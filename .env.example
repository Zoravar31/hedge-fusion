# ================================================================
# HedgeFusion — Complete Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub — it's in .gitignore.
# ================================================================

# ── AI Model (Required) ──────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
# Add ₹500–1000 in credits under Billing before running.
OPENAI_API_KEY=sk-your-key-here

# Model to use for all agents:
#   gpt-4o-mini → ₹2–5 per stock    (recommended for paper testing)
#   gpt-4o      → ₹20–50 per stock  (recommended for live trading decisions)
#   gpt-4.1     → latest, balanced
MODEL_NAME=gpt-4o-mini


# ── Trading Mode ─────────────────────────────────────────────
# ALWAYS start with true. Switch to false only after 4+ weeks of paper testing.
#   true  = paper trades  (simulated, logs to logs/paper_trades.csv)
#   false = live trades   (real Zerodha orders — real money!)
KITE_PAPER_TRADE=true


# ── Zerodha Kite Connect (live trading only) ──────────────────
# Steps to get credentials:
#   1. Go to https://developers.kite.trade/ → sign in with Zerodha
#   2. Create App → fill form → pay ₹2,000/year developer fee
#   3. Copy API Key and API Secret below
#   4. Every morning before trading, run: python tools/kite_login.py
#      This auto-fills KITE_ACCESS_TOKEN below (valid until 6:30 PM IST)
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=


# ── Portfolio ─────────────────────────────────────────────────
# Total portfolio value in INR. Used by Risk Manager for position sizing.
# Also update HOLDINGS list in config.py with your actual qty and avg_buy_price.
PORTFOLIO_SIZE_INR=500000


# ── Scheduler (autonomous mode) ───────────────────────────────
# Controls python scheduler.py — runs pipeline automatically each trading day.
# SCHEDULE_MODE: daily (once at SCHEDULE_TIME) or interval (every N hours)
# SCHEDULE_TIME: when to run (IST, 24h format). 09:30 = just after market open.
# SCHEDULE_TICKERS: comma-separated NSE tickers to run daily
# SCHEDULE_EXECUTE: true = auto-execute PM-approved orders | false = analysis only
SCHEDULE_MODE=daily
SCHEDULE_TIME=09:30
SCHEDULE_TICKERS=ICICIBANK,BHARTIARTL,ZOMATO,M&M,LT,MAZDOCK,BEL,HDFCBANK,HINDZINC,VBL
SCHEDULE_EXECUTE=false
SCHEDULE_INTERVAL_HOURS=24


# ── Alert Channels (optional but recommended) ─────────────────
# Configure at least one channel to get alerts when:
#   - A watchlist stock enters BUY ZONE
#   - PM approves an order
#   - A holding hits stop loss
#   - Daily portfolio digest

# TELEGRAM (free, recommended)
# Setup:
#   1. Open Telegram → search @BotFather → /newbot → follow steps → copy token
#   2. Send /start to your new bot
#   3. Visit https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#      Find "chat":{"id": 123456789} → that is your CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# EMAIL via Gmail SMTP (free)
# Setup:
#   1. Enable 2FA on Gmail
#   2. Go to Google Account → Security → App Passwords → generate one
#   3. Fill in sender (your Gmail), password (app password), recipient
ALERT_EMAIL_SENDER=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_RECIPIENT=

# WHATSAPP via Twilio (paid, ~₹2–5 per message)
# Setup:
#   1. Sign up at https://twilio.com (free trial available)
#   2. Enable WhatsApp sandbox in console → join with your WhatsApp number
#   3. Fill in your Twilio credentials and phone numbers
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX


# ── Risk Thresholds (advanced) ────────────────────────────────
# These match the defaults in config.py — only change if you want
# different risk limits than the defaults.
# MAX_POSITION_PCT=15        # alert if any stock >15% of portfolio
# MAX_SECTOR_PCT=30          # alert if any sector >30%
# MIN_RISK_REWARD=2.0        # PM veto if R:R < 2.0
# STOP_LOSS_DEFAULT_PCT=5.0  # default SL if agent doesn't set one
